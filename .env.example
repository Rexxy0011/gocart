# Currency Symbol
NEXT_PUBLIC_CURRENCY_SYMBOL=₦

# Supabase — get these from your project's API settings
# (Project Settings → API → URL + anon public key + service_role key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin allowlist — comma-separated emails that can access /admin/*.
# Empty in dev = wide open (any signed-in user is treated as admin).
# Set this to your real admin emails before deploying anywhere public.
# Example: ADMIN_EMAILS=founder@example.com,ops@example.com
ADMIN_EMAILS=

# Paystack — get these from dashboard.paystack.com → Settings → API Keys
# Test keys are stable; replace with pk_live_/sk_live_ in production.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Public origin used by Paystack to redirect users back after payment.
# Override per environment (e.g. https://gocart.app in production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phone OTP uses Supabase's native phone auth, which delegates to a Twilio
# (or other) SMS provider configured in the Supabase dashboard:
#   Authentication → Providers → Phone → enable + paste Twilio creds
# No env vars needed in this app — it all flows through the existing
# NEXT_PUBLIC_SUPABASE_* variables and the user's session.

# Tier-1 verification (email + phone). Flip to "true" only after Twilio is
# configured in Supabase + Confirm-email is on, otherwise signed-in users
# get bounced to a /verify page that can't actually send OTPs.
VERIFICATION_REQUIRED=false
