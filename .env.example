# Currency Symbol
NEXT_PUBLIC_CURRENCY_SYMBOL=₦

# Supabase — get these from your project's API settings
# (Project Settings → API → URL + anon public key + service_role key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin allowlist — comma-separated emails that can access /admin/*.
# Empty in dev = wide open (any signed-in user is treated as admin).
# Set this to your real admin emails before deploying anywhere public.
# Example: ADMIN_EMAILS=founder@example.com,ops@example.com
ADMIN_EMAILS=

# Paystack — get these from dashboard.paystack.com → Settings → API Keys
# Test keys are stable; replace with pk_live_/sk_live_ in production.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Public origin used by Paystack to redirect users back after payment.
# Override per environment (e.g. https://gocart.app in production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
